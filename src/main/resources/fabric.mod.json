{
  "schemaVersion": 1,
  "id": "cobalt",
  "version": "${version}",
  "name": "Cobalt",
  "description": "A Hypixel Skyblock QoL mod for Fabric 1.21.10",
  "authors": ["quiteboring", "Twiston", "oblongboot"],
  "contact": {
    "homepage": "https://cobalt.quiteboring.dev/",
    "sources": "https://github.com/CobaltScripts/Cobalt"
  },
  "license": "GPL-3.0",
  "icon": "assets/cobalt/icon.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      {
        "adapter": "kotlin",
        "value": "org.cobalt.Cobalt"
      }
    ]
  },
  "mixins": ["cobalt.mixins.json"],
  "accessWidener": "cobalt.accesswidener",
  "depends": {
    "java": ">=25",
    "fabric-api": "*",
    "fabric-language-kotlin": "*",
    "fabricloader": ">=${fabricLoaderVersion}",
    "minecraft": "~${minecraftVersion}"
  }
}
